<%= render 'layouts/header' %>

<div class="h-auto lg:flex justify-center">
  <div class="lg:w-[600px] lg:px-[32px] py-[16px] px-[16px] bg-white lg:bg-[unset]">
    <div class="text-center lg:mb-6 pb-[16px] border-b border-[rgba(0,0,0,0.1)]">
      <h1 class="text-2xl lg:text-3xl font-bold text-bnb_blue leading-tight">
        Statement Generation Portal
      </h1>
    </div>
    <div class="rounded-[22px] bg-white lg:bg-[#F6F6F6]">
      <div class="lg:flex" data-controller="account-verification">
        <div class="flex-1 px-[16px] py-[16px] lg:py-[32px] lg:px-[32px] overflow-y-auto">

          <!-- Verification Code Header with Icon -->
          <div class="mb-[24px] flex items-start justify-center">
            <i class="material-symbols-outlined text-bnb_blue mr-[12px] text-[28px]">verified_user</i>
            <div>
              <h2 class="text-lg font-semibold text-bnb_blue mb-[4px]">Verification Code</h2>
              <p class="text-sm text-gray-600">
                We have sent the verification code to your email address
              </p>
            </div>
          </div>

          <%= form_with url: verify_otp_verification_index_path(account_id: @verification.id), method: :post, local: true do |f| %>
            <div>
              <!-- Hidden field to store complete OTP -->
              <%= f.hidden_field :otp, data: { account_verification_target: "otpField" } %>
              
              <!-- Four OTP input boxes -->
              <div class="flex justify-center space-x-[16px] mb-[24px]">
                <% 4.times do |i| %>
                  <input
                    type="text"
                    maxlength="1"
                    class="otp-input w-[60px] h-[60px] text-center text-2xl font-bold border-2 border-gray-300 rounded-lg focus:border-bnb_blue focus:outline-none"
                    data-account-verification-target="otpInput"
                    data-index="<%= i %>"
                    data-action="input->account-verification#handleOTPInput 
                                keydown->account-verification#handleKeydown 
                                paste->account-verification#handlePaste"
                    inputmode="numeric"
                    pattern="[0-9]"
                  />
                <% end %>
              </div>

              <div class="flex space-x-[16px] justify-center my-[24px]">
                <button
                  data-account-verification-target="submitButton"
                  class="btn-blue-bnb flex items-center disabled:opacity-50 disabled:cursor-not-allowed"
                  type="submit"
                  disabled>
                  <i class="material-symbols-outlined !text-[20px] text-white mr-[8px] ml-[2px]">check_circle</i>
                  Confirm
                </button>
              </div>
            </div>
          <% end %>

          <!-- Resend OTP button OUTSIDE the form -->
          <div class="mt-3 text-center">
            <p class="text-sm text-gray-600 flex items-center justify-center gap-1">
              You didn't receive any code?
              <%= link_to "Resend OTP",
                resend_otp_verification_index_path(account_id: @statement.id),
                data: { turbo_method: :post },
                class: "text-bnb_blue font-semibold" %>
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>